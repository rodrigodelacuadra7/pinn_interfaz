# Copia este archivo a .env y ajusta los valores para producción

DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Rutas al modelo (dentro del contenedor, via volumen)
MODEL_PATH=/models/model_fase2_seed2718.pt
SCALERS_PATH=/models/scalers_trial16.pkl

# Para desarrollo local sin Docker, usar rutas relativas al repo:
# MODEL_PATH=../model_fase2_seed2718.pt
# SCALERS_PATH=../scalers_trial16.pkl
